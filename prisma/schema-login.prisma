generator loginClient {
  provider = "prisma-client-js"
  output   = "../src/@generated/login-client"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_LOGIN_URL")
}

model User {
  userId            String   @id @db.Char(128)
  password          String   @default("123456") @db.Char(128)
  loginTime         DateTime @default(dbgenerated("'2021-01-01 00:00:00'")) @db.DateTime(0)
  createTime        DateTime @default(dbgenerated("'2021-01-01 00:00:00'")) @db.DateTime(0)
  outTime           DateTime @default(dbgenerated("'2021-01-01 00:00:00'")) @db.DateTime(0)
  ip                String   @default("") @db.Char(24)
  loginCount        Int      @default(0)
  platform          Int      @default(0)
  isWhite           Int      @default(0) @db.TinyInt
  serverId          Int
  name              String   @db.VarChar(24)
  type              Int      @default(0) @db.TinyInt
  serverIp          String   @default("") @db.Char(24)
  serverAdminPort   String   @default("") @db.Char(24)
  loginDays         Int      @default(0)
  onlineMin         Int      @default(0)
  maxStage          Int      @default(0)
  pumpCount         Int      @default(0)
  extUserData       String?  @db.LongText
  lastLoginServerId Int
  email             String?  @db.VarChar(255)
  phone             String?  @db.VarChar(32)

  @@index([userId], map: "ind_e_id")
  @@index([name], map: "ind_e_name")
  @@index([outTime], map: "ind_e_outTime")
  @@index([platform], map: "ind_e_platform")
  @@index([serverId], map: "ind_e_serverid")
  @@map("user")
}

model PortalAccessSession {
  jti       String    @id @db.VarChar(64)
  userId    String    @map("user_id") @db.Char(128)
  expiresAt DateTime  @map("expires_at") @db.DateTime(0)
  revokedAt DateTime? @map("revoked_at") @db.DateTime(0)

  @@index([userId], map: "ind_portal_sess_user")
  @@map("portal_access_session")
}

model DepositPromotion {
  id        String   @id @default(uuid()) @db.VarChar(36)
  percent   Int
  startAt   DateTime @map("start_at") @db.DateTime(0)
  endAt     DateTime @map("end_at") @db.DateTime(0)
  isActive  Boolean  @default(true) @map("is_active")
  label     String?  @db.VarChar(128)
  createdAt DateTime @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt DateTime @updatedAt @map("updated_at") @db.DateTime(0)

  @@map("deposit_promotion")
}

model DepositRequest {
  id                   String   @id @default(uuid()) @db.VarChar(36)
  userId               String   @map("user_id") @db.Char(128)
  amount               Int
  method               String   @db.VarChar(16)
  note                 String   @db.VarChar(256)
  server               String   @db.VarChar(16)
  status               String   @default("pending") @db.VarChar(16)
  adminNote            String?  @map("admin_note") @db.VarChar(512)
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")
  bonusAmount          Int      @default(0) @map("bonus_amount")
  promoPercentSnapshot Int?     @map("promo_percent_snapshot")

  @@index([userId], map: "ind_dr_user")
  @@index([status], map: "ind_dr_status")
  @@map("deposit_request")
}

model TicketConversion {
  id             String   @id @default(uuid()) @db.VarChar(36)
  userId         String   @map("user_id") @db.Char(128)
  amount         Int
  tickets        Int
  conversionRate Int      @map("conversion_rate")
  createdAt      DateTime @default(now()) @map("created_at")
  serverId       Int      @default(0) @map("server_id")
  playerUid      String   @default("") @map("player_uid") @db.Char(24)
  playerName     String   @default("") @map("player_name") @db.VarChar(32)

  @@index([userId], map: "ind_tc_user")
  @@index([serverId], map: "ind_tc_server")
  @@map("ticket_conversion")
}

model ShopItem {
  id             String   @id @default(uuid()) @db.VarChar(36)
  externalItemId Int      @map("external_item_id")
  itemName       String   @map("item_name") @db.VarChar(128)
  itemQuantity   Int      @map("item_quantity")
  price          Int
  imageUrl       String?  @map("image_url") @db.VarChar(512)
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([isActive], map: "ind_shop_item_active")
  @@map("shop_item")
}

model ShopOrder {
  id                String   @id @default(uuid()) @db.VarChar(36)
  userId            String   @map("user_id") @db.Char(128)
  shopItemId        String   @map("shop_item_id") @db.VarChar(36)
  externalItemId    Int      @map("external_item_id")
  itemName          String   @map("item_name") @db.VarChar(128)
  unitItemQuantity  Int      @map("unit_item_quantity")
  buyQuantity       Int      @map("buy_quantity")
  totalItemQuantity Int      @map("total_item_quantity")
  unitPrice         Int      @map("unit_price")
  totalPrice        Int      @map("total_price")
  serverId          Int      @map("server_id")
  playerUid         String   @map("player_uid") @db.Char(24)
  playerName        String   @map("player_name") @db.VarChar(32)
  createdAt         DateTime @default(now()) @map("created_at")

  @@index([userId], map: "ind_shop_order_user")
  @@index([shopItemId], map: "ind_shop_order_item")
  @@map("shop_order")
}

model activationcode {
  id    String @id @db.Char(12)
  batch Int
  code  String @db.Char(15)

  @@index([id], map: "ind_ac_id")
  @@map("activationcode")
}

model activationcodeinfo {
  id         Int      @id
  name       String   @db.VarChar(32)
  channel    String   @db.VarChar(64)
  vipLevel   Int      @default(0)
  bonusesStr String   @db.VarChar(512)
  expiryDate DateTime @default(dbgenerated("'2012-01-01 00:00:00'")) @db.DateTime(0)
  useType    String   @default("0") @db.Char(4)
  addFlag    Int      @default(0)

  @@index([id], map: "ind_aci_id")
  @@map("activationcodeinfo")
}

model useactivationcoderecord {
  id         Int      @id
  playerId   String   @db.Char(24)
  batch      Int
  code       String   @db.Char(15)
  createTime DateTime @default(dbgenerated("'2012-01-01 00:00:00'")) @db.DateTime(0)

  @@index([batch], map: "ind_uacr_batch")
  @@index([code], map: "ind_uacr_code")
  @@index([playerId], map: "ind_uacr_playerId")
  @@map("useactivationcoderecord")
}

model NewsPost {
  id          String   @id @default(uuid()) @db.VarChar(36)
  title       String   @db.VarChar(255)
  slug        String   @unique @db.VarChar(255)
  excerpt     String   @db.VarChar(512)
  content     String   @db.LongText
  coverImage  String?  @map("cover_image") @db.VarChar(512)
  isFeatured  Boolean  @default(false) @map("is_featured")
  isPublished Boolean  @default(false) @map("is_published")
  publishedAt DateTime? @map("published_at")
  createdBy   String   @map("created_by") @db.Char(128)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([isPublished, publishedAt], map: "ind_news_published")
  @@index([isFeatured], map: "ind_news_featured")
  @@map("news_post")
}

model AdminAccess {
  userId      String   @id @map("user_id") @db.Char(128)
  role        String   @db.VarChar(32)
  permissions Json
  isActive    Boolean  @default(true) @map("is_active")
  createdBy   String?  @map("created_by") @db.Char(128)
  createdAt   DateTime @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.DateTime(0)

  @@index([role], map: "ind_admin_access_role")
  @@map("admin_access")
}

model AdminRolePermission {
  role        String   @id @db.VarChar(32)
  permissions Json
  updatedBy   String?  @map("updated_by") @db.Char(128)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.DateTime(0)

  @@map("admin_role_permission")
}

model GameServerSetting {
  id        String   @id @default(uuid()) @db.VarChar(36)
  code      String   @unique @db.VarChar(32)
  name      String   @db.VarChar(128)
  host      String?  @db.VarChar(255)
  isActive  Boolean  @default(true) @map("is_active")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt DateTime @updatedAt @map("updated_at") @db.DateTime(0)

  @@index([isActive], map: "ind_game_server_setting_active")
  @@map("game_server_setting")
}

model PaymentMethodSetting {
  id            String   @id @default(uuid()) @db.VarChar(36)
  code          String   @unique @db.VarChar(32)
  name          String   @db.VarChar(128)
  channel       String   @db.VarChar(32)
  accountName   String?  @map("account_name") @db.VarChar(128)
  accountNumber String?  @map("account_number") @db.VarChar(64)
  phoneNumber   String?  @map("phone_number") @db.VarChar(32)
  qrTemplate    String?  @map("qr_template") @db.VarChar(1024)
  banks         Json?
  isActive      Boolean  @default(true) @map("is_active")
  sortOrder     Int      @default(0) @map("sort_order")
  createdAt     DateTime @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.DateTime(0)

  @@index([isActive], map: "ind_payment_method_setting_active")
  @@map("payment_method_setting")
}

model SupportTicket {
  id            String   @id @default(uuid()) @db.VarChar(36)
  userId        String   @map("user_id") @db.Char(128)
  characterName String?  @map("character_name") @db.VarChar(64)
  serverName    String?  @map("server_name") @db.VarChar(64)
  title         String   @db.VarChar(255)
  content       String   @db.Text
  status        String   @default("open") @db.VarChar(16)
  adminReply    String?  @map("admin_reply") @db.Text
  createdAt     DateTime @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.DateTime(0)

  @@index([userId, createdAt], map: "ind_support_ticket_user_created")
  @@index([status], map: "ind_support_ticket_status")
  @@map("support_ticket")
}

model SupportChannel {
  id        String   @id @default(uuid()) @db.VarChar(36)
  code      String   @unique @db.VarChar(32)
  name      String   @db.VarChar(128)
  url       String   @db.VarChar(512)
  icon      String?  @db.VarChar(64)
  isActive  Boolean  @default(true) @map("is_active")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt DateTime @updatedAt @map("updated_at") @db.DateTime(0)

  @@index([isActive, sortOrder], map: "ind_support_channel_active_sort")
  @@map("support_channel")
}

model announcement {
  platform     Int      @id
  announcement String   @db.LongText
  time         DateTime @default(dbgenerated("'2019-01-01 00:00:00'")) @db.DateTime(0)

  @@index([platform], map: "ind_e_platform")
}

model configserver {
  id        Int      @id
  name      String   @db.VarChar(48)
  mergeId   Int
  status    Int      @db.TinyInt
  desc      String   @db.VarChar(256)
  isSsl     Int      @db.TinyInt
  host      String   @db.Char(24)
  redis     Int
  debug     Int
  pay       Int
  admin     Int
  websocket Int
  watchdog  Int
  deployId  Int
  state     Int      @db.TinyInt
  gameDir   String   @db.VarChar(512)
  inst      String   @db.VarChar(128)
  dbname    String   @db.VarChar(128)
  type      String   @db.Char(24)
  regCount  Int
  openTime  DateTime @default(dbgenerated("'2021-01-01 00:00:00'")) @db.DateTime(0)
  platform  String   @db.VarChar(256)
  ip        String   @db.VarChar(256)

  @@index([deployId], map: "ind_cs_deployId")
  @@index([mergeId], map: "ind_cs_mergeId")
  @@index([name], map: "ind_cs_name")
  @@index([state], map: "ind_cs_state")
  @@index([type], map: "ind_cs_type")
}

model publicconfig {
  id    Int @id
  maxID Int
}

model serverinfo {
  id            Int       @id
  state         Int?
  nextState     Int?
  nextStateTime DateTime? @db.DateTime(0)
  desc          String?   @db.VarChar(255)
  name          String?   @db.VarChar(255)
  token         String?   @db.VarChar(255)
}
