PORT=4000
NODE_ENV=development
# Base không có tên DB (code nối /login) — hoặc chỉ cần dòng dưới
DATABASE_URL="mysql://root:your_password@your_host:3306"
# URL đầy đủ DB login; bắt buộc khớp khi chạy: prisma migrate deploy --schema prisma/schema-login.prisma
DATABASE_LOGIN_URL="mysql://root:your_password@your_host:3306/login"
JWT_ACCESS_SECRET="your_access_secret"
JWT_REFRESH_SECRET="your_refresh_secret"
ACCESS_TOKEN_EXPIRES_IN="15m"
REFRESH_TOKEN_EXPIRES_IN="7d"
ADMIN_USER_IDS=""
ADMIN_TYPES="1"
