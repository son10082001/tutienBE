{
  "name": "tutien-be",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "prebuild": "prisma generate --schema prisma/schema-login.prisma && prisma generate --schema prisma/schema-game.prisma",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "postinstall": "prisma generate --schema prisma/schema-login.prisma && prisma generate --schema prisma/schema-game.prisma",
    "prisma:generate": "prisma generate --schema prisma/schema-login.prisma && prisma generate --schema prisma/schema-game.prisma",
    "migrate:login": "node scripts/migrate-login.mjs",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.6.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "ws": "^8.20.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.10.2",
    "@types/ws": "^8.18.1",
    "prisma": "^6.6.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
